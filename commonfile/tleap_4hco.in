import sklearn.discriminant_analysis as lda

# Load the dataset
data = pd.read_csv('iris.csv')

# Split the data into features and labels
features = data.iloc[:, :-1]
labels = data.iloc[:, -1]

# Create an LDA model
lda_model = lda.LinearDiscriminantAnalysis()

# Fit the model to the data
lda_model.fit(features, labels)

# Predict the labels for new data
new_features = pd.DataFrame({'sepal_length': [5.1, 5.0], 'sepal_width': [3.5, 3.5], 'petal_length': [1.4, 1.4], 'petal_width': [0.2, 0.2]})

new_labels = lda_model.predict(new_features)

print(new_labels)


