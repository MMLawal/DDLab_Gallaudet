6A within Ligand union
import MDAnalysis as mda
import numpy as np
from scipy.spatial.distance import cdist

def extract_residues_within_radius(traj_file, topology_file, ligand_resname='LIG', radius=6.0):
    # Load the trajectory and topology using MDAnalysis
    u = mda.Universe(topology_file, traj_file)

    # Select the ligand atoms
    ligand_atoms = u.select_atoms(f'resname {ligand_resname}')

    # Set to store unique residue IDs across all frames
    all_residues = set()

    # Loop through each frame of the trajectory
    for ts in u.trajectory:
        # Update positions for the current frame
        u.trajectory[ts.frame]

        # Extract coordinates of ligand atoms
        ligand_positions = ligand_atoms.positions

        # Select all atoms in the system
        all_atoms = u.atoms
        all_atom_positions = all_atoms.positions

        # Calculate distances from all atoms to ligand atoms
        distances = cdist(all_atom_positions, ligand_positions)

        # Find atoms within the specified radius from the ligand
        within_radius = np.any(distances < radius, axis=1)

        # Extract residues of atoms within the radius
        binding_pocket_residues = all_atoms[within_radius].residues

        # Add unique residues to the set
        residues_info = {(residue.resid, residue.resname) for residue in binding_pocket_residues}
        all_residues.update(residues_info)

    return all_residues

def save_union_residues_results(all_residues, output_file):
    """Save union of residues results to a text file."""
    with open(output_file, 'w') as f:
        f.write("Residue ID\tResidue Name\n")
        for res_id, res_name in sorted(all_residues):
            f.write(f"{res_id}\t{res_name}\n")
    print(f"Union of residues within 6 Å saved to '{output_file}'.")

# Example usage
if __name__ == "__main__":
    traj_file = 'bs1_tq_300ns.dcd'  # Path to trajectory file
    topology_file = 'bs1_tq_redo.prmtop'  # Path to topology file
    ligand_resname = 'LIG'  # Update to your ligand's residue name

    output_file = 'union_residues_within_6A.txt'  # Output file name

    # Extract residues within 6 Å of the ligand across all frames
    all_residues = extract_residues_within_radius(traj_file, topology_file, ligand_resname, radius=6.0)

    # Save the union of residues results to text file
    save_union_residues_results(all_residues, output_file)


