    "PLX2 (89)": [0, 10, 0, 4, 0, 0, 0, 4, 20, 3, 4, 3, 0, 0, 0, 0, 7, 0, 3, 0, 4, 14],
    "PLX23 (91)": [0,8,0,3,0,0,0,0,0,0,8,5,26,4,0,4,22,12,0,0,0,0],
    "–(–)9* at BS1-2 (314)": [9,116,28,71,10,3,18,34,4,0,3,0,0,0,7,0,9,0,0,0,0,0],
    "–(+)9* at BS1-2 (281)": [0,99,5,89,29,0,28,13,0,0,16,0,0,0,0,0,3,0,0,0,0,0],
    "Allopole-A (114)": [13,27,0,0,0,0,0,27,3,15,0,0,0,0,0,3,4,0,11,4,0,0]
}

labels = [
    "LYS413", "TRP414", "VAL415", "ASP416", "TYR417", "TYR481", "TYR485",
    "LEU490", "LEU491", "ALA493", "ARG516", "THR517", "ARG518", "ALA520",
    "ILE521", "ASN533", "PHE535", "GLN536", "HIS538", "LYS540", "GLU555", "ARG557"
]

# Convert percentage strings to float values
