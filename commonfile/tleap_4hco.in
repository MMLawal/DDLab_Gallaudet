import mdtraj as md

# Define functions for calculating grid points and volume
def create_grid(protein, ligand_residues, probe_radius, grid_spacing):
  """
  Creates a grid around the ligand in the protein structure.
  """
  center = protein.top.select_atoms('resid '+str(ligand_residues[0])).xyz[0]
  min_x, max_x = center[0] - probe_radius, center[0] + probe_radius
  min_y, max_y = center[1] - probe_radius, center[1] + probe_radius
  min_z, max_z = center[2] - probe_radius, center[2] + probe_radius
  x, y, z = np.mgrid[min_x:max_x+grid_spacing:grid_spacing,
                     min_y:max_y+grid_spacing:grid_spacing,
                     min_z:max_z+grid_spacing:grid_spacing]
  return x, y, z

def calculate_volume(protein, ligand_residues, probe_radius, grid_spacing):
  """
  Calculates the accessible volume around the ligand using a grid approach.
  """
  x, y, z = create_grid(protein, ligand_residues, probe_radius, grid_spacing)
  grid_points = np.vstack((x.ravel(), y.ravel(), z.ravel())).T
  distances = md.compute_distances(grid_points, protein.xyz)
  accessible_points = np.sum(distances <= probe_radius, axis=1)
  return np.sum(accessible_points) * grid_spacing**3

# Load trajectory and define parameters
trajectory = md.load('prot2_c-9_b.dcd', top='prot2_c-9_b_gas.pdb')
ligand_residues = [10, 11, 12]  # Adjust based on your system
probe_radius = 1.4  # Adjust based on your needs
grid_spacing = 0.5  # Adjust based on desired accuracy

# Calculate volume for each trajectory frame
volumes = []
for i in range(trajectory.n_frames):
  frame = trajectory[i]
  volume = calculate_volume(frame, ligand_residues, probe_radius, grid_spacing)
  volumes.append(volume)

