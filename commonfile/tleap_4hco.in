import numpy as np

def combine_datasets(filenames):
  """
  Combines multiple datasets (x and y data) into a single dataset.

  Args:
      filenames (list): A list of strings representing the filenames of the datasets.

  Returns:
      tuple: A tuple containing two NumPy arrays. The first array contains the combined x data,
              and the second array contains the combined y data.
  """

  # Initialize empty lists for combined data
  combined_x = []
  combined_y = []

  # Loop through each filename
  for filename in filenames:
    # Load data from each file
    data = np.loadtxt(filename)

    # Separate x and y data
    x = data[:, 0]
    y = data[:, 1]

    # Append data to combined lists
    combined_x.extend(x)
    combined_y.extend(y)

  # Convert lists to NumPy arrays
  combined_x = np.array(combined_x)
  combined_y = np.array(combined_y)

  return combined_x, combined_y

# Example usage
filenames = ["wt_bias1.dat", "wt_bias2.dat", "wt_bias3.dat", "wt_bias4.dat", "wt_bias5.dat", "wt_bias6.dat"]
combined_x, combined_y = combine_datasets(filenames)

# Now you can use the combined_x and combined_y arrays for further analysis or plotting
print(combined_x.shape)
print(combined_y.shape)



