# Convert to DataFrame
df = pd.DataFrame(data)
df.set_index('Protein-inhibitor', inplace=True)
 
# Create the heatmap
plt.figure(figsize=(10, 20))  # Adjust height to accommodate all y-axis labels
sns.heatmap(
    df,
    annot=True,          # Set to True if you want to display the values
    fmt=".1f",
    cmap="coolwarm",
    linewidths=0.5,
    cbar_kws={'label': 'Binding Score'}
)

# Adjust y-axis labels
plt.yticks(fontsize=8, rotation=0)  # Smaller font size and no rotation
plt.xticks(fontsize=10)
 
# Ensure no labels are cut off
plt.tight_layout()
 
# Display the heatmap
plt.show()


