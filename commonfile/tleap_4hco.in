New
import MDAnalysis as mda
import numpy as np
from scipy.spatial import ConvexHull
from scipy.spatial.distance import cdist

def compute_convex_hull_volume(points):
    """Compute the volume of the convex hull for given points."""
    if len(points) < 4:
        return 0.0  # Need at least 4 points to define a 3D volume

    try:
        hull = ConvexHull(points)
        return hull.volume
    except:
        # Skip if ConvexHull calculation fails (e.g., collinear points)
        return 0.0

def calculate_binding_pocket_volumes(traj_file, topology_file, ligand_selection):
    # Load the trajectory using MDAnalysis
    u = mda.Universe(topology_file, traj_file)

    # Select the ligand atoms
    ligand_atoms = u.select_atoms(ligand_selection)

    # Calculate volume for the region within 4 Å of the ligand
    all_volumes = []

    for ts in u.trajectory:
        # Get positions of ligand atoms
        if len(ligand_atoms) > 0:
            ligand_positions = ligand_atoms.positions

            # Select all atoms in the system
            all_atoms = u.atoms
            all_atom_positions = all_atoms.positions

            # Calculate distances from all atoms to ligand atoms
            distances = cdist(all_atom_positions, ligand_positions)

            # Find atoms within 4 Å from the ligand
            within_4A = np.any(distances < 4, axis=1)

            # Extract positions of atoms within 4 Å from the ligand
            nearby_atoms_positions = all_atom_positions[within_4A]

            # Calculate convex hull volume using these atoms
            if len(nearby_atoms_positions) > 3:  # Need at least 4 points to define a volume
                volume = compute_convex_hull_volume(nearby_atoms_positions)
            else:
                volume = 0.0
        else:
            volume = 0.0

        all_volumes.append(volume)

    return all_volumes

def save_volumes(volumes, output_file):
    with open(output_file, 'w') as f:
        f.write("Frame\tVolume (Å³)\n")
        for i, vol in enumerate(volumes):
            f.write(f"{i+1}\t{vol:.3f}\n")
    print(f"Binding pocket volumes saved to '{output_file}'.")

# Example usage:
if __name__ == "__main__":
    traj_file = 'bs1_tq_300ns.dcd'  # Path to trajectory file
    topology_file = 'bs1_tq_redo.prmtop'  # Path to topology file (PDB format)

    # Selection for ligand atoms
    ligand_selection = 'resname LIG'  # Update 'LIG' to your ligand's residue name

    output_file = 'ligand_nearby_atoms_volumes.txt'  # Output file name

    volumes = calculate_binding_pocket_volumes(traj_file, topology_file, ligand_selection)

    # Save volumes to text files
    save_volumes(volumes, output_file)



