For Apo
import MDAnalysis as mda
from scipy.spatial import ConvexHull
import numpy as np

# Function to calculate binding pocket volume for apo protein
def calculate_binding_pocket_volume(traj_file, topology_file, selection):
    # Load the trajectory using MDAnalysis
    u = mda.Universe(topology_file, traj_file)

    # Selection for the binding site (modify as per your system)
    binding_site_atoms = u.select_atoms(selection)

    # Calculate volume for each frame
    volumes = []
    for ts in u.trajectory:
        # Calculate center of mass of binding site atoms
        binding_site_center = binding_site_atoms.center_of_mass()

        # Calculate distances from binding site center to binding site atoms
        distances = np.linalg.norm(binding_site_atoms.positions - binding_site_center, axis=1)

        # Determine which atoms are within the binding site
        within_site = distances <= 5.0  # Adjust threshold as needed (in Angstroms)

        # Extract coordinates of atoms within the binding site
        site_atoms_positions = binding_site_atoms.positions[within_site]

        # Calculate volume using Convex Hull method from Scipy
        if len(site_atoms_positions) > 3:  # Need at least 4 points to define a volume
            hull = ConvexHull(site_atoms_positions)
            volume = hull.volume
        else:
            volume = 0.0

        volumes.append(volume)

    return volumes

# Function to save volumes to a text file
def save_volumes(volumes, output_file):
    with open(output_file, 'w') as f:
        f.write("Frame\tVolume (Å³)\n")
        for i, vol in enumerate(volumes):
            f.write(f"{i+1}\t{vol:.3f}\n")

# Example usage:
if __name__ == "__main__":
    traj_file = 'trajectory.dcd'  # Path to trajectory file
    topology_file = 'topology.pdb'  # Path to topology file (PDB format)
    selection = 'protein'  # Selection for binding site (e.g., 'protein and name CA')
    output_file = 'binding_pocket_volumes_apo.txt'  # Output file to save volumes

    volumes = calculate_binding_pocket_volume(traj_file, topology_file, selection)
    
    # Save volumes to a text file
    save_volumes(volumes, output_file)
    
    print(f"Binding pocket volumes for apo protein saved to '{output_file}'.")

