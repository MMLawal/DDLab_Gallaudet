# uniform weights
train, cv = scripts.cross_validate_cluster_scan(traj_data, 10000, covar_type="kronecker", cluster_array = cluster_array, n_training_sets=3, n_attempts = 10, dtype=torch.float32, device=torch.device("cpu"))

