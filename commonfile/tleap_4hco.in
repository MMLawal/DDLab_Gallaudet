from MDAnalysis import Universe

def calculate_pocket_volume(pdb_file, ligand_residues, probe_radius=1.4):
  """
  Calculates the binding pocket volume for a single frame in a PDB file.

  Args:
      pdb_file: Path to the PDB file.
      ligand_residues: List of residue names of the ligand.
      probe_radius: Probe radius used by MSMS (default: 1.4 Angstrom).

  Returns:
      The volume of the binding pocket (Angstrom^3).
  """
  u = Universe(pdb_file)
  protein = u.select_atoms('protein')  # Select all protein atoms
  ligand = u.select_atoms(f"name {' '.join(ligand_residues)}")  # Select ligand atoms

  # Define the binding pocket as solvent accessible surface around ligand
  pocket = protein.add_solvent_accessible_surface(probe_radius=probe_radius)
  pocket -= ligand  # Exclude ligand from the pocket definition

  # Calculate the volume of the pocket
  volume = pocket.volume

  return volume

def analyze_trajectory(trajectory_file, ligand_residues, output_file):
  """
  Analyzes the binding pocket volume for all frames in a trajectory

  Args:
      trajectory_file: Path to the trajectory file (e.g., DCD file)
      ligand_residues: List of residue names of the ligand.
      output_file: Path to save the pocket volume data.
  """
  u = Universe(trajectory_file, format='DCD')  # Assuming DCD format
  volumes = []
  for frame in u.trajectory:
    volume = calculate_pocket_volume(u.slice, ligand_residues)
    volumes.append(volume)

  # Save the pocket volume data to a file
  with open(output_file, 'w') as f:
    f.write("Frame\tVolume (Angstrom^3)\n")
    for i, volume in enumerate(volumes):
      f.write(f"{i+1}\t{volume}\n")

# Example usage
trajectory_file = "path/to/your/trajectory.dcd"
ligand_residues = ["LIG"]  # Replace with your ligand residue names
output_file = "pocket_volume.txt"

analyze_trajectory(trajectory_file, ligand_residues, output_file)

