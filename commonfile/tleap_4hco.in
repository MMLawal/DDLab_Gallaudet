import MDAnalysis
from MDAnalysis.analysis.hydrogenbonds.hbond_analysis import (HydrogenBondAnalysis as HBA)

u = MDAnalysis.Universe(bs1_tq_redo.top, bs1_tq_300ns.dcd)

hbonds = HBA(universe=u, between=['resname TIP3', 'protein'])

protein_hydrogens_sel = hbonds.guess_hydrogens("protein")
protein_acceptors_sel = hbonds.guess_acceptors("protein")

ligand_hydrogens_sel = "resname LIG and name H*"
ligand_acceptors_sel = "resname LIG and name O* N* S* F* Cl*"

hbonds.hydrogens_sel = f"({protein_hydrogens_sel}) or ({ligand_hydrogens_sel})"
hbonds.acceptors_sel = f"({protein_acceptors_sel}) or ({ligand_acceptors_sel})"

hbonds.run()

# Iterate over each frame of the trajectory
for ts in u.trajectory:
    # Hydrophobic interaction: Calculate distances between protein and ligand hydrophobic atoms
    hydrophobic_distances = distance_array(protein_hydrophobic.positions, ligand_hydrophobic.positions)
    hydrophobic_interacting_pairs = np.where(hydrophobic_distances < hydrophobic_cutoff)

    # For each interacting hydrophobic atom, increase the count for the residue it belongs to
    for i in hydrophobic_interacting_pairs[0]:
        residue_index = protein_hydrophobic[i].resid
        hydrophobic_counts[residue_index] += 1

    # van der Waals interaction: Calculate distances between protein and ligand atoms
    vdw_distances = distance_array(protein_atoms.positions, ligand_atoms.positions)
    vdw_interacting_pairs = np.where(vdw_distances < vdw_cutoff)

    # For each interacting vdW atom, increase the count for the residue it belongs to
    for i in vdw_interacting_pairs[0]:
        residue_index = protein_atoms[i].resid
        vdw_counts[residue_index] += 1

# Hydrogen bonding analysis (from previously run hbonds)
for hbond in hbonds.hbonds:  # 'hbonds.hbonds' contains info for all frames
    frame, donor_idx, hydrogen_idx, acceptor_idx, distance, angle = hbond

    # Safely retrieve atoms by their indices
    try:
        donor_atom = u.atoms[int(donor_idx)]
        acceptor_atom = u.atoms[int(acceptor_idx)]
    except IndexError:
        continue  # Skip any bad indices

    # Get residue IDs for both donor and acceptor
    donor_resid = donor_atom.resid
    acceptor_resid = acceptor_atom.resid

    # Increment the count for the residues involved in hydrogen bonding
    hbonds_per_residue[donor_resid] += 1
    hbonds_per_residue[acceptor_resid] += 1
# Calculate percent occupancy for each residue for hydrophobic, vdW, and hydrogen bonds
hydrophobic_occupancy = {resid: (count / total_frames) * 100 for resid, count in hydrophobic_counts.items()}
vdw_occupancy = {resid: (count / total_frames) * 100 for resid, count in vdw_counts.items()}
hbond_occupancy = {resid: (count / total_frames) * 100 for resid, count in hbonds_per_residue.items()}

# Open a file to write the percent occupancy results
with open('interaction_percent_occupancy.csv', 'w') as output_file:
    output_file.write('Residue,Hydrophobic Occupancy (%),vdW Occupancy (%),H-bond Occupancy (%)\n')
    all_residues = set(hydrophobic_occupancy.keys()).union(vdw_occupancy.keys()).union(hbond_occupancy.keys())
    for resid in all_residues:
        h_occ = hydrophobic_occupancy.get(resid, 0)
        vdw_occ = vdw_occupancy.get(resid, 0)
        hbond_occ = hbond_occupancy.get(resid, 0)
        output_file.write(f'{resid},{h_occ:.2f},{vdw_occ:.2f},{hbond_occ:.2f}\n')

# Prepare data for plotting
residues = list(all_residues)
hydrophobic_percents = [hydrophobic_occupancy.get(resid, 0) for resid in residues]
vdw_percents = [vdw_occupancy.get(resid, 0) for resid in residues]
hbond_percents = [hbond_occupancy.get(resid, 0) for resid in residues]

# Sort residues by hydrophobic occupancy for better visualization
sorted_residues, sorted_hydro, sorted_vdw, sorted_hbond = zip(*sorted(zip(residues, hydrophobic_percents, vdw_percents, hbond_percents)
, key=lambda x: x[1], reverse=True))



