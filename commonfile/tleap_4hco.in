import MDAnalysis as mda
from MDAnalysis.analysis.distances import distance_array
import numpy as np
import matplotlib.pyplot as plt

# Load the topology and trajectory files
u = mda.Universe('bs1_tq_redo.top', 'bs1_tq_300ns.dcd')

# Define hydrophobic residues (common hydrophobic residues)
hydrophobic_residues = ['VAL', 'LEU', 'ILE', 'LYS', 'HIS', 'GLU', 'TYR', 'PHE', 'MET', 'PRO', 'ALA', 'GLY', 'CYS', 'TRP']

# Select hydrophobic atoms in the protein and ligand
protein_hydrophobic = u.select_atoms(f"protein and (resname {' '.join(hydrophobic_residues)})")
ligand_hydrophobic = u.select_atoms("resname LIG")  # Adjust 'LIG' to match your ligand name

# Select atoms of the protein and ligand for van der Waals interaction
protein_atoms = u.select_atoms('protein')
ligand_atoms = u.select_atoms('resname LIG')  # Adjust 'LIG' to match your ligand name

# Define cutoff distances for hydrophobic and vdW interactions
hydrophobic_cutoff = 2.3  # Hydrophobic interaction cutoff (in Angstroms)
vdw_cutoff = 2.5  # van der Waals interaction cutoff (in Angstroms)

# Initialize lists to store hydrophobic interactions and vdW bonds over time
hydrophobic_interactions = []
vdw_bonds = []

# Open a file to write both hydrophobic and vdW results
with open('interactions.csv', 'w') as output_file:
    output_file.write('Frame,Hydrophobic Interactions,vdW Bonds\n')  # Write the header

    # Iterate over each frame of the trajectory
    for ts in u.trajectory:
        # Hydrophobic interaction: Calculate distances between protein and ligand hydrophobic atoms
        hydrophobic_distances = distance_array(protein_hydrophobic.positions, ligand_hydrophobic.positions)
        num_hydrophobic_interactions = np.sum(hydrophobic_distances < hydrophobic_cutoff)

        # van der Waals interaction: Calculate distances between protein and ligand atoms
        vdw_distances = distance_array(protein_atoms.positions, ligand_atoms.positions)
        num_vdw_bonds = np.sum(vdw_distances < vdw_cutoff)

        # Store the interactions for this frame
        hydrophobic_interactions.append(num_hydrophobic_interactions)
        vdw_bonds.append(num_vdw_bonds)

        # Write the frame number, hydrophobic interactions, and vdW bonds to the file
        output_file.write(f'{ts.frame},{num_hydrophobic_interactions},{num_vdw_bonds}\n')

# Plot hydrophobic interactions over time
plt.figure(figsize=(10, 6))
plt.plot(hydrophobic_interactions, label='Hydrophobic Interactions')
plt.plot(vdw_bonds, label='Number of vdW Bonds', color='orange')
plt.xlabel('Frame')
plt.ylabel('Number')
#plt.title('Hydrophobic Interactions Over Time')
plt.legend()
plt.grid(True)
#plt.savefig('hydrophobic_interactions_plot.png', dpi=300)  # Optionally save the plot
plt.show()


import MDAnalysis as mda
from MDAnalysis.analysis.distances import distance_array
from MDAnalysis.analysis.hydrogenbonds.hbond_analysis import HydrogenBondAnalysis as HBA
import numpy as np
import matplotlib.pyplot as plt
from collections import defaultdict

# Load the topology and trajectory files
u = mda.Universe('bs1_tq_redo.top', 'bs1_tq_300ns.dcd')

# Define hydrophobic residues (common hydrophobic residues)
hydrophobic_residues = ['ARG', 'ASP', 'VAL', 'LEU', 'ILE', 'LYS', 'HIS', 'GLU', 'TYR', 'PHE', 'MET', 'PRO', 'ALA', 'CYS', 'TRP']

# Select hydrophobic atoms in the protein and ligand
protein_hydrophobic = u.select_atoms(f"protein and (resname {' '.join(hydrophobic_residues)})")
ligand_hydrophobic = u.select_atoms("resname LIG")  # Adjust 'LIG' to match your ligand name

# Select atoms of the protein and ligand for van der Waals interaction
protein_atoms = u.select_atoms('protein')
ligand_atoms = u.select_atoms('resname LIG')  # Adjust 'LIG' to match your ligand name

# Define cutoff distances for hydrophobic and vdW interactions
hydrophobic_cutoff = 2.4  # Hydrophobic interaction cutoff (in Angstroms)
vdw_cutoff = 2.45  # van der Waals interaction cutoff (in Angstroms)

# Initialize dictionaries to track interactions for each residue
hydrophobic_counts = defaultdict(int)
vdw_counts = defaultdict(int)
hbonds_per_residue = defaultdict(int)  # For hydrogen bonds

# Total number of frames
total_frames = len(u.trajectory)

# Set up Hydrogen Bond Analysis (HBA)
hydrogens_sel = 'protein and name H*'  # Hydrogen atoms in the protein
acceptors_sel = 'resname LIG and name O* N* S* F* Cl*'  # Acceptors in the ligand

hbonds = HBA(universe=u, hydrogens_sel=hydrogens_sel, acceptors_sel=acceptors_sel, d_a_cutoff=3.5)
hbonds.run()
# Iterate over each frame of the trajectory
for ts in u.trajectory:
    
# Hydrogen bonding analysis (from previously run hbonds)
for hbond in hbonds.hbonds:  # 'hbonds.hbonds' contains info for all frames
    frame, donor_idx, hydrogen_idx, acceptor_idx, distance, angle = hbond

    # Safely retrieve atoms by their indices
    try:
        donor_atom = u.atoms[int(donor_idx)]
        acceptor_atom = u.atoms[int(acceptor_idx)]
    except IndexError:
        continue  # Skip any bad indices

    # Get residue IDs for both donor and acceptor
    donor_resid = donor_atom.resid
    acceptor_resid = acceptor_atom.resid

    # Increment the count for the residues involved in hydrogen bonding
    hbonds_per_residue[donor_resid] += 1
    hbonds_per_residue[acceptor_resid] += 1
# Calculate percent occupancy for each residue for hydrophobic, vdW, and hydrogen bonds
hydrophobic_occupancy = {resid: (count / total_frames) * 100 for resid, count in hydrophobic_counts.items()}
vdw_occupancy = {resid: (count / total_frames) * 100 for resid, count in vdw_counts.items()}
hbond_occupancy = {resid: (count / total_frames) * 100 for resid, count in hbonds_per_residue.items()}

# Open a file to write the percent occupancy results
with open('interaction_percent_occupancy.csv', 'w') as output_file:
    output_file.write('Residue,Hydrophobic Occupancy (%),vdW Occupancy (%),H-bond Occupancy (%)\n')
    all_residues = set(hydrophobic_occupancy.keys()).union(vdw_occupancy.keys()).union(hbond_occupancy.keys())
    for resid in all_residues:
        h_occ = hydrophobic_occupancy.get(resid, 0)
        vdw_occ = vdw_occupancy.get(resid, 0)
        hbond_occ = hbond_occupancy.get(resid, 0)
        output_file.write(f'{resid},{h_occ:.2f},{vdw_occ:.2f},{hbond_occ:.2f}\n')

# Prepare data for plotting
residues = list(all_residues)
hydrophobic_percents = [hydrophobic_occupancy.get(resid, 0) for resid in residues]
vdw_percents = [vdw_occupancy.get(resid, 0) for resid in residues]
hbond_percents = [hbond_occupancy.get(resid, 0) for resid in residues]

# Sort residues by hydrophobic occupancy for better visualization
sorted_residues, sorted_hydro, sorted_vdw, sorted_hbond = zip(*sorted(zip(residues, hydrophobic_percents, vdw_percents, hbond_percents)
, key=lambda x: x[1], reverse=True))

# Plot hydrophobic, vdW, and H-bond interaction occupancy
plt.figure(figsize=(10, 6))

bar_width = 0.25
index = np.arange(len(sorted_residues))

plt.barh(index, sorted_hydro, bar_width, label='Hydrophobic Occupancy (%)', color='lightblue')
plt.barh(index + bar_width, sorted_vdw, bar_width, label='vdW Occupancy (%)', color='orange')
plt.barh(index + 2 * bar_width, sorted_hbond, bar_width, label='H-bond Occupancy (%)', color='lightgreen')

plt.xlabel('Percent Occupancy (%)')
plt.ylabel('Residue')
plt.title('Hydrophobic, vdW, and H-bond Interaction Occupancy per Residue')
plt.yticks(index + bar_width, sorted_residues)
plt.legend()
plt.grid(True)

# Optionally save the plot
#plt.savefig('interaction_occupancy_plot.png', dpi=300)

# Display the plot
plt.tight_layout()
plt.show()


import MDAnalysis as mda
from MDAnalysis.analysis.distances import distance_array
from MDAnalysis.analysis.hydrogenbonds.hbond_analysis import HydrogenBondAnalysis as HBA
import numpy as np
import matplotlib.pyplot as plt
from collections import defaultdict

# Load the topology and trajectory files
u = mda.Universe('bs1_tq_redo.top', 'bs1_tq_300ns.dcd')

# Define hydrophobic residues (common hydrophobic residues)
hydrophobic_residues = ['ARG', 'SER', 'ASP', 'VAL', 'LEU', 'ILE', 'LYS', 'HIS', 'GLU', 'TYR', 'PHE', 'MET', 'PRO', 'ALA', 'GLY', 'CYS',
 'TRP']

# Select hydrophobic atoms in the protein and ligand
protein_hydrophobic = u.select_atoms(f"protein and (resname {' '.join(hydrophobic_residues)})")
ligand_hydrophobic = u.select_atoms("resname LIG")  # Adjust 'LIG' to match your ligand name

# Select atoms of the protein and ligand for van der Waals interaction
protein_atoms = u.select_atoms('protein')
ligand_atoms = u.select_atoms('resname LIG')  # Adjust 'LIG' to match your ligand name

# Define cutoff distances for hydrophobic and vdW interactions
hydrophobic_cutoff = 2.4  # Hydrophobic interaction cutoff (in Angstroms)
vdw_cutoff = 2.45  # van der Waals interaction cutoff (in Angstroms)

# Initialize lists to track contacts over time
hydrophobic_contacts_per_frame = []
vdw_contacts_per_frame = []
hbond_contacts_per_frame = []

# Set up Hydrogen Bond Analysis (HBA)
hydrogens_sel = 'protein and name H*'  # Hydrogen atoms in the protein
acceptors_sel = 'resname LIG and name O* N* S* F* Cl*'  # Acceptors in the ligand

hbonds = HBA(universe=u, hydrogens_sel=hydrogens_sel, acceptors_sel=acceptors_sel, d_a_cutoff=3.5)
hbonds.run()

# Total number of frames
total_frames = len(u.trajectory)
# Open a CSV file to write the number of contacts per frame
with open('contacts_over_time.csv', 'w') as output_file:
    output_file.write('Frame,Hydrophobic Contacts,vdW Contacts,H-bond Contacts\n')

    # Iterate over each frame of the trajectory
    for ts in u.trajectory:
        # Hydrophobic interaction: Calculate distances between protein and ligand hydrophobic atoms
        hydrophobic_distances = distance_array(protein_hydrophobic.positions, ligand_hydrophobic.positions)
        num_hydrophobic_contacts = np.sum(hydrophobic_distances < hydrophobic_cutoff)

        # van der Waals interaction: Calculate distances between protein and ligand atoms
        vdw_distances = distance_array(protein_atoms.positions, ligand_atoms.positions)
        num_vdw_contacts = np.sum(vdw_distances < vdw_cutoff)

        # Hydrogen bonding interaction: Check for hydrogen bonds in this frame
        hbond_contacts = [hbond for hbond in hbonds.hbonds if hbond[0] == ts.frame]
        num_hbond_contacts = len(hbond_contacts)

        # Store the number of contacts for this frame
        hydrophobic_contacts_per_frame.append(num_hydrophobic_contacts)
        vdw_contacts_per_frame.append(num_vdw_contacts)
        hbond_contacts_per_frame.append(num_hbond_contacts)

        # Write the data to the file
        output_file.write(f'{ts.frame},{num_hydrophobic_contacts},{num_vdw_contacts},{num_hbond_contacts}\n')

# Plot the number of contacts over time
plt.figure(figsize=(10, 6))

# Plot hydrophobic contacts over time
plt.plot(hydrophobic_contacts_per_frame, label='Hydrophobic Contacts', color='blue')

# Plot vdW contacts over time
plt.plot(vdw_contacts_per_frame, label='vdW Contacts', color='orange')

# Plot H-bond contacts over time
plt.plot(hbond_contacts_per_frame, label='H-bond Contacts', color='green')

plt.xlabel('Frame')
plt.ylabel('Number of Contacts')
plt.title('Number of Contacts Over Simulation Time')
plt.legend()
plt.grid(True)

# Optionally save the plot
#plt.savefig('contacts_over_time_plot.png', dpi=300)

# Display the plot
plt.tight_layout()
plt.show()


