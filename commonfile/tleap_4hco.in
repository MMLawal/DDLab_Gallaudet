import numpy as np
import matplotlib.pyplot as plt
from scipy.interpolate import griddata

# Load FES data
data7 = np.loadtxt('fes_2d.dat', comments='#')

# Extract unique values
x = np.unique(data[:, 0]*10)  # Unique distance1 values
y = np.unique(data[:, 1]*10)  # Unique distance2 values

# Check for matching grid size
if len(data) == len(y) * len(x):
    z = data[:, 2].reshape(len(y), len(x))  # Reshape directly
else:
    # Interpolate if grid size doesn't match
    X, Y = np.meshgrid(x, y)
    Z = griddata((data[:, 0]*10, data[:, 1]*10), data[:, 2]/4.184, (X, Y), method='linear')
    z = Z  # Use interpolated Z

# Plot FES as a contour plot
plt.figure(figsize=(8, 6))
contour = plt.contourf(x, y, z, levels=20, cmap='viridis')
cbar = plt.colorbar(contour)
cbar.set_label('Free Energy (kJ/mol)', fontsize=12)

# Labels and title
plt.xlabel('Distance 1 (A)', fontsize=14)
plt.ylabel('Distance 2 (A)', fontsize=14)
plt.title('2D Free Energy Surface', fontsize=16)
plt.grid(alpha=0.3)

plt.tight_layout()
plt.show()


