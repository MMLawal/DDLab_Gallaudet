    data[key] = [float(str(v).replace('%', '')) for v in data[key]]

# Plot settings
bar_width = 0.1
index = np.arange(len(labels))

# Create figure and axis
fig, ax = plt.subplots(figsize=(18, 10))
# Create figure and axis
fig, ax = plt.subplots(figsize=(18, 10))

# Plot bars for each column of data
for i, (key, values) in enumerate(data.items()):
    ax.bar(index + i * bar_width, values, bar_width, label=key)

# Add labels and title
ax.set_xlabel('Residues')
ax.set_ylabel('H-Bond Occupancy Percentage (%)')
#ax.set_title('Bar Chart of Residue Interaction Percentages')
ax.set_xticks(index + bar_width * 3)
ax.set_xticklabels(labels, rotation=90)

# Add legend
ax.legend()

# Show plot
plt.tight_layout()
plt.savefig('bs1-hb.png', dpi=500)
plt.show()

